{
  "title": "HK Real-Time Traffic — Smart Lamppost Detectors",
  "uid": "hk-traffic-slp",
  "tags": ["traffic", "speed", "volume", "smart-lamppost"],
  "timezone": "Asia/Hong_Kong",
  "refresh": "2m",
  "schemaVersion": 36,
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    { "id": 1, "title": "Active Detectors (latest batch)", "type": "stat", "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 }, "datasource": "PostgreSQL", "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }, "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "unit": "none", "decimals": 0 } }, "targets": [{ "rawSql": "SELECT COUNT(DISTINCT detector_id) FROM traffic_speed_volume WHERE fetched_at >= (SELECT MAX(fetched_at) - INTERVAL '2 minutes' FROM traffic_speed_volume);", "format": "table", "refId": "A" }] },
    { "id": 2, "title": "Avg Speed — All Detectors (km/h)", "type": "stat", "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 }, "datasource": "PostgreSQL", "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }, "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "orange", "value": 30 }, { "color": "green", "value": 60 }] }, "unit": "velocitykmh", "decimals": 0 } }, "targets": [{ "rawSql": "SELECT ROUND(AVG(speed)) FROM traffic_speed_volume WHERE speed > 0 AND fetched_at >= (SELECT MAX(fetched_at) - INTERVAL '2 minutes' FROM traffic_speed_volume);", "format": "table", "refId": "A" }] },
    { "id": 3, "title": "Total Vehicles Counted (latest batch)", "type": "stat", "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 }, "datasource": "PostgreSQL", "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }, "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" }, "unit": "locale", "decimals": 0 } }, "targets": [{ "rawSql": "SELECT SUM(volume) FROM traffic_speed_volume WHERE fetched_at >= (SELECT MAX(fetched_at) - INTERVAL '2 minutes' FROM traffic_speed_volume);", "format": "table", "refId": "A" }] },
    { "id": 4, "title": "Congested Detectors (speed < 30 km/h)", "type": "stat", "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 }, "datasource": "PostgreSQL", "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }, "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "orange", "value": 5 }, { "color": "red", "value": 15 }] }, "unit": "none", "decimals": 0 } }, "targets": [{ "rawSql": "SELECT COUNT(DISTINCT detector_id) FROM traffic_speed_volume WHERE speed > 0 AND speed < 30 AND fetched_at >= (SELECT MAX(fetched_at) - INTERVAL '2 minutes' FROM traffic_speed_volume);", "format": "table", "refId": "A" }] },
    { "id": 5, "title": "Average Speed Over Time (All Detectors)", "type": "timeseries", "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 }, "datasource": "PostgreSQL", "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "list", "placement": "bottom" } }, "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 }, "color": { "mode": "fixed", "fixedColor": "green" }, "unit": "velocitykmh" } }, "targets": [{ "rawSql": "SELECT DATE_TRUNC('minute', fetched_at) AS time, ROUND(AVG(speed)) AS \"Avg Speed (km/h)\" FROM traffic_speed_volume WHERE speed > 0 AND fetched_at > NOW() - INTERVAL '3 hours' GROUP BY DATE_TRUNC('minute', fetched_at) ORDER BY time;", "format": "time_series", "refId": "A" }] },
    { "id": 6, "title": "Average Speed by District (latest batch)", "type": "barchart", "gridPos": { "x": 0, "y": 12, "w": 14, "h": 10 }, "datasource": "PostgreSQL", "options": { "orientation": "horizontal", "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" }, "barWidth": 0.6, "xTickLabelSpacing": 80 }, "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 80 }, "unit": "velocitykmh", "min": 0, "max": 80 } }, "targets": [{ "rawSql": "SELECT l.district, ROUND(AVG(t.speed)) AS avg_speed_kmh FROM traffic_speed_volume t JOIN traffic_detector_locations l ON t.detector_id = l.aid_id WHERE t.speed > 0 AND t.fetched_at >= (SELECT MAX(fetched_at) - INTERVAL '2 minutes' FROM traffic_speed_volume) GROUP BY l.district ORDER BY avg_speed_kmh ASC LIMIT 15;", "format": "table", "refId": "A" }] },
    { "id": 7, "title": "Vehicle Volume by District (latest batch)", "type": "barchart", "gridPos": { "x": 14, "y": 12, "w": 10, "h": 10 }, "datasource": "PostgreSQL", "options": { "orientation": "horizontal", "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" }, "barWidth": 0.6 }, "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 80 }, "unit": "short" } }, "targets": [{ "rawSql": "SELECT l.district, SUM(t.volume) AS total_vehicles FROM traffic_speed_volume t JOIN traffic_detector_locations l ON t.detector_id = l.aid_id WHERE t.fetched_at >= (SELECT MAX(fetched_at) - INTERVAL '2 minutes' FROM traffic_speed_volume) GROUP BY l.district ORDER BY total_vehicles DESC LIMIT 15;", "format": "table", "refId": "A" }] },
    { "id": 8, "title": "Speed by Lane Type (latest batch)", "type": "barchart", "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 }, "datasource": "PostgreSQL", "options": { "orientation": "vertical", "legend": { "displayMode": "list", "placement": "bottom" }, "barWidth": 0.5 }, "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "fillOpacity": 80 }, "unit": "velocitykmh" } }, "targets": [{ "rawSql": "SELECT lane_id, ROUND(AVG(speed)) AS avg_speed FROM traffic_speed_volume WHERE speed > 0 AND fetched_at >= (SELECT MAX(fetched_at) - INTERVAL '2 minutes' FROM traffic_speed_volume) GROUP BY lane_id ORDER BY avg_speed DESC;", "format": "table", "refId": "A" }] },
    { "id": 9, "title": "Latest Readings — All Detectors", "type": "table", "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 }, "datasource": "PostgreSQL", "options": { "sortBy": [{ "displayName": "Speed (km/h)", "desc": false }] }, "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [{ "matcher": { "id": "byName", "options": "speed" }, "properties": [{ "id": "displayName", "value": "Speed (km/h)" }, { "id": "unit", "value": "velocitykmh" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "orange", "value": 30 }, { "color": "green", "value": 60 }] } }, { "id": "custom.displayMode", "value": "color-background" }] }, { "matcher": { "id": "byName", "options": "volume" }, "properties": [{ "id": "displayName", "value": "Vehicles" }] }] }, "targets": [{ "rawSql": "SELECT DISTINCT ON (t.detector_id) l.district, l.road_en, t.detector_id, t.direction, t.lane_id, t.speed, t.volume, t.fetched_at FROM traffic_speed_volume t JOIN traffic_detector_locations l ON t.detector_id = l.aid_id WHERE t.speed > 0 ORDER BY t.detector_id, t.fetched_at DESC LIMIT 50;", "format": "table", "refId": "A" }] }
  ]
}
