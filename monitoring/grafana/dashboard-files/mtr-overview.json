{
  "title": "MTR Overview",
  "uid": "mtr-overview",
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "line", "label": "Line", "type": "query",
        "datasource": { "type": "postgres", "uid": "postgres" },
        "definition": "SELECT DISTINCT line FROM mtr.eta ORDER BY line",
        "query": "SELECT DISTINCT line FROM mtr.eta ORDER BY line",
        "refresh": 2, "sort": 1, "multi": false, "includeAll": true, "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1, "title": "Total MTR Rows Collected",
      "type": "stat", "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "rawSql": "SELECT COUNT(*) AS value FROM mtr.eta", "format": "table", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "id": 2, "title": "Lines Tracked",
      "type": "stat", "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "rawSql": "SELECT COUNT(DISTINCT line) AS value FROM mtr.eta", "format": "table", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } } }
    },
    {
      "id": 3, "title": "Avg Wait (last hour)",
      "type": "stat", "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "rawSql": "SELECT ROUND(AVG(wait_minutes)::numeric, 1) AS value FROM mtr.eta WHERE eta_seq = 1 AND fetched_at > NOW() - INTERVAL '1 hour'", "format": "table", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "none", "displayName": "Avg Wait (min)", "color": { "mode": "fixed", "fixedColor": "orange" } } }
    },
    {
      "id": 4, "title": "Stations Tracked",
      "type": "stat", "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "rawSql": "SELECT COUNT(DISTINCT station) AS value FROM mtr.eta", "format": "table", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "purple" } } }
    },
    {
      "id": 5, "title": "Avg Wait by Line (all data)",
      "type": "bargauge", "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "rawSql": "SELECT line AS \"Line\", ROUND(AVG(wait_minutes)::numeric, 1) AS \"Avg Wait (min)\" FROM mtr.eta WHERE eta_seq = 1 AND wait_minutes IS NOT NULL GROUP BY line ORDER BY line", "format": "table", "refId": "A" }],
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 4 }, { "color": "red", "value": 8 } ] }, "color": { "mode": "thresholds" } } }
    },
    {
      "id": 6, "title": "P95 Wait by Line (all data)",
      "type": "bargauge", "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "rawSql": "SELECT line AS \"Line\", ROUND(PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY wait_minutes)::numeric, 1) AS \"P95 Wait (min)\" FROM mtr.eta WHERE eta_seq = 1 AND wait_minutes IS NOT NULL GROUP BY line ORDER BY line", "format": "table", "refId": "A" }],
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] }, "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 6 }, { "color": "red", "value": 12 } ] }, "color": { "mode": "thresholds" } } }
    },
    {
      "id": 7, "title": "MTR Wait Over Time",
      "type": "timeseries", "gridPos": { "x": 0, "y": 12, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT DATE_TRUNC('minute', fetched_at) AT TIME ZONE 'Asia/Hong_Kong' AS time, line, ROUND(AVG(wait_minutes)::numeric, 1) AS \"Avg Wait (min)\" FROM mtr.eta WHERE eta_seq = 1 AND fetched_at > NOW() - INTERVAL '3 hours' GROUP BY DATE_TRUNC('minute', fetched_at), line ORDER BY 1",
        "format": "time_series", "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "id": 8, "title": "Avg Wait by Hour of Day — per Line",
      "type": "table", "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "rawSql": "SELECT line AS \"Line\", station AS \"Station\", dir AS \"Dir\", hour_of_day AS \"Hour\", avg_wait_min AS \"Avg Wait\", p95_wait_min AS \"P95 Wait\", sample_count AS \"Samples\" FROM mtr.v_station_hourly ORDER BY line, station, dir, hour_of_day", "format": "table", "refId": "A" }],
      "options": { "sortBy": [{ "displayName": "Avg Wait", "desc": true }] },
      "fieldConfig": { "defaults": { "custom": { "align": "left", "displayMode": "auto" } } }
    }
  ]
}
