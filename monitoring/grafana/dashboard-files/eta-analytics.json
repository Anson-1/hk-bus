{
  "title": "ETA Analytics",
  "uid": "eta-analytics",
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "route",
        "label": "Route",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "postgres"
        },
        "definition": "SELECT DISTINCT route FROM eta_realtime ORDER BY route",
        "query": "SELECT DISTINCT route || ' [' || COALESCE(co, 'KMB') || ']' AS __text, route AS __value FROM eta_realtime ORDER BY route",
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "dir",
        "label": "Direction",
        "type": "custom",
        "query": "O,I",
        "options": [
          {
            "value": "O",
            "text": "Outbound"
          },
          {
            "value": "I",
            "text": "Inbound"
          }
        ],
        "current": {
          "value": "O",
          "text": "Outbound"
        }
      },
      {
        "name": "stop",
        "label": "Stop",
        "type": "query",
        "datasource": {
          "type": "postgres",
          "uid": "postgres"
        },
        "definition": "SELECT e.stop_id AS __value, COALESCE(s.name_en, e.stop_id) AS __text FROM (SELECT DISTINCT stop_id FROM eta_realtime WHERE route = '${route}' AND dir = '${dir}') e LEFT JOIN stops s ON e.stop_id = s.stop_id ORDER BY __text",
        "query": "SELECT e.stop_id AS __value, COALESCE(s.name_en, e.stop_id) AS __text FROM (SELECT DISTINCT stop_id FROM eta_realtime WHERE route = '${route}' AND dir = '${dir}') e LEFT JOIN stops s ON e.stop_id = s.stop_id ORDER BY __text",
        "refresh": 2,
        "sort": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Routes Tracked",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(DISTINCT route) AS value FROM eta_realtime",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 2,
      "title": "Stops Tracked (selected route)",
      "type": "stat",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(DISTINCT stop_id) AS value FROM eta_realtime WHERE route = '$route' AND dir = '$dir'",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 3,
      "title": "Total Data Points Collected",
      "type": "stat",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT COUNT(*) AS value FROM eta_realtime",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          },
          "unit": "short"
        }
      }
    },
    {
      "id": 4,
      "title": "Wait Time History \u2014 $route ($stop)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT window_start AS \"time\", ROUND((avg_wait_sec / 60.0)::numeric, 1) AS \"Avg Wait (min)\" FROM eta_realtime WHERE route = '$route' AND dir = '$dir' AND stop_id = '$stop' AND $__timeFilter(window_start) ORDER BY window_start",
          "format": "time_series"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 5,
      "title": "Current Avg Wait \u2014 All Stops on $route ($dir)",
      "type": "table",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "targets": [
        {
          "rawSql": "SELECT DISTINCT ON (e.stop_id) COALESCE(s.name_en, e.stop_id) AS \"Stop\", ROUND((e.avg_wait_sec / 60.0)::numeric, 1) AS \"Avg Wait (min)\" FROM eta_realtime e LEFT JOIN stops s ON e.stop_id = s.stop_id WHERE e.route = '$route' AND e.dir = '$dir' ORDER BY e.stop_id, e.window_start DESC",
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Avg Wait (min)"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 160
              },
              {
                "id": "custom.align",
                "value": "center"
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 10
                    },
                    {
                      "color": "red",
                      "value": 20
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": []
      }
    }
  ]
}