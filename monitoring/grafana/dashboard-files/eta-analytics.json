{
  "title": "KMB Delay Overview",
  "uid": "kmb-delay-overview",
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1, "title": "Total Rows Collected",
      "type": "stat", "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "rawSql": "SELECT COUNT(*) AS value FROM kmb.eta", "format": "table", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "id": 2, "title": "Routes Tracked",
      "type": "stat", "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "rawSql": "SELECT COUNT(DISTINCT route) AS value FROM kmb.eta", "format": "table", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } } }
    },
    {
      "id": 3, "title": "Delay Rate (last hour)",
      "type": "stat", "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "rawSql": "SELECT ROUND(100.0 * SUM(CASE WHEN remarks LIKE 'Delayed journey%' OR remarks = 'Moving slowly' THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 1) AS value FROM kmb.eta WHERE eta_seq = 1 AND fetched_at > NOW() - INTERVAL '1 hour'", "format": "table", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 5 } ] }, "color": { "mode": "thresholds" } } }
    },
    {
      "id": 4, "title": "Stops with Data",
      "type": "stat", "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "rawSql": "SELECT COUNT(DISTINCT stop_id) AS value FROM kmb.eta", "format": "table", "refId": "A" }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "orange" } } }
    },
    {
      "id": 5, "title": "Delay Events Over Time (5-min buckets)",
      "type": "timeseries", "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{
        "rawSql": "SELECT (DATE_TRUNC('hour', fetched_at) + FLOOR(EXTRACT(MINUTE FROM fetched_at)/5)*INTERVAL '5 minutes') AT TIME ZONE 'Asia/Hong_Kong' AS time, ROUND(100.0 * SUM(CASE WHEN remarks LIKE 'Delayed journey%' OR remarks = 'Moving slowly' THEN 1 ELSE 0 END) / NULLIF(COUNT(*),0), 2) AS \"Delay %\" FROM kmb.eta WHERE eta_seq = 1 AND fetched_at > NOW() - INTERVAL '3 hours' GROUP BY 1 ORDER BY 1",
        "format": "time_series", "refId": "A"
      }],
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "id": 6, "title": "Top 20 Worst Routes (all collected data)",
      "type": "table", "gridPos": { "x": 0, "y": 12, "w": 24, "h": 10 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "rawSql": "SELECT route AS \"Route\", route_name AS \"Route Name\", dir AS \"Dir\", total_samples AS \"Samples\", true_delay_count AS \"Delays\", delay_pct AS \"Delay %\", avg_wait_min AS \"Avg Wait\", p95_wait_min AS \"P95 Wait\" FROM kmb.v_worst_routes LIMIT 20", "format": "table", "refId": "A" }],
      "options": { "sortBy": [{ "displayName": "Delay %", "desc": true }] },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left", "displayMode": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Delay %" }, "properties": [ { "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 8 } ] } } ] },
          { "matcher": { "id": "byName", "options": "Avg Wait" }, "properties": [ { "id": "unit", "value": "none" }, { "id": "displayName", "value": "Avg Wait (min)" } ] },
          { "matcher": { "id": "byName", "options": "P95 Wait" }, "properties": [ { "id": "unit", "value": "none" }, { "id": "displayName", "value": "P95 Wait (min)" } ] }
        ]
      }
    },
    {
      "id": 7, "title": "Recent Delay Events (last hour)",
      "type": "table", "gridPos": { "x": 0, "y": 22, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "postgres" },
      "targets": [{ "rawSql": "SELECT fetched_at AT TIME ZONE 'Asia/Hong_Kong' AS \"Time\", route_name AS \"Route\", stop_name AS \"Stop\", delay_type AS \"Type\", remarks AS \"Remarks\", wait_minutes AS \"Wait (min)\" FROM kmb.v_recent_delays LIMIT 50", "format": "table", "refId": "A" }],
      "options": { "sortBy": [{ "displayName": "Time", "desc": true }] },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left", "displayMode": "auto" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Type" }, "properties": [ { "id": "custom.displayMode", "value": "color-background" }, { "id": "mappings", "value": [ { "type": "value", "options": { "delay": { "color": "red", "index": 0 }, "final_bus": { "color": "blue", "index": 1 } } } ] } ] }
        ]
      }
    }
  ]
}
